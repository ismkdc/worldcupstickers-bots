# Telegram bot credentials (create a bot via @BotFather)
TELEGRAM_BOT_TOKEN=123456789:your-bot-token-here
# Target chat / channel / group id (use -100... for supergroups & channels)
TELEGRAM_CHAT_ID=-1001234567890
# Optional: forum/group topic (thread) id; if set, messages go to that topic
TELEGRAM_THREAD_ID=
# Seconds between full scans
CHECK_INTERVAL_SECONDS=300
# Number of concurrent workers
WORKERS=16
